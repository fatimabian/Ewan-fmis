DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.151.8.59

DB_ENGINE=mysql
MYSQL_DATABASE=fmis
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ALLOW_LEGACY_MARIADB=True

# Public Google Identity Services Web client ID. Do not add a client secret.
GOOGLE_OAUTH_CLIENT_ID=

# Optional SMTP configuration. Without it, password-reset links print in the terminal.
DEFAULT_FROM_EMAIL=FMIS <noreply@example.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Verified portable backups created by: python manage.py backup_fmis
FMIS_BACKUP_ROOT=backups
