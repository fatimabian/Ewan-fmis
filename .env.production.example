# Generate a new value; never reuse this example:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-unique-random-secret-of-at-least-50-characters
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=fmis.example.gov.ph
DJANGO_CSRF_TRUSTED_ORIGINS=https://fmis.example.gov.ph
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_HSTS_SECONDS=31536000
DJANGO_BEHIND_HTTPS_PROXY=False

DB_ENGINE=mysql
MYSQL_DATABASE=fmis
MYSQL_USER=fmis_app
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ALLOW_LEGACY_MARIADB=False

FMIS_BACKUP_ROOT=C:/FMIS/backups
GOOGLE_OAUTH_CLIENT_ID=
DEFAULT_FROM_EMAIL=FMIS <noreply@example.gov.ph>
EMAIL_HOST=smtp.example.gov.ph
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
